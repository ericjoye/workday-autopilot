{
  "manifest_version": 3,
  "name": "Workday Autopilot",
  "version": "0.1.0",
  "description": "Auto-fill and auto-submit Workday job applications. One click, done.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["*://*.workday.com/*", "*://*.myworkdayjobs.com/*"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {"16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png"}
  },
  "icons": {"16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png"},
  "background": {"service_worker": "background/service-worker.js"},
  "options_ui": {"page": "options/options.html", "open_in_tab": false},
  "content_scripts": [{
    "matches": ["*://*.workday.com/*", "*://*.myworkdayjobs.com/*"],
    "js": ["content/content-script.js"],
    "css": ["content/content-style.css"]
  }]
}
